# Local dev: FastAPI URL. Vercel production: omit or set to "" for same-origin /api (see vercel.json rewrites).
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/dashboard

# OAuth (frontend must use VITE_ prefix)
VITE_GOOGLE_CLIENT_ID=
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_ORIGIN_ALT=http://localhost:5173
FRONTEND_ORIGIN_LOOPBACK=http://127.0.0.1:5173
FRONTEND_ORIGIN_LOOPBACK_ALT=http://127.0.0.1:3000

DATABASE_URL=sqlite+aiosqlite:///./cynapse.db
# Required: strong random secret (e.g. openssl rand -hex 32). Placeholders are rejected unless:
JWT_SECRET_KEY=
ALLOW_WEAK_JWT_FOR_LOCAL_DEV=true
JWT_ACCESS_TOKEN_MINUTES=120
JWT_REFRESH_TOKEN_DAYS=7
SETTINGS_ENCRYPTION_KEY=change-me-in-production
# Server-side Gemini only in production. Set true only for legacy dev to accept X-Gemini-Key from clients.
ALLOW_CLIENT_GEMINI_KEY=false
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
# Optional: comma-separated extra browser origins for CORS (multiple prod/staging frontends).
# CORS_EXTRA_ORIGINS=https://app.example.com,https://staging.example.com
# Optional: set to 1 to allow any https://*.vercel.app preview origin (only if previews are not listed above).
# CORS_ALLOW_VERCEL_PREVIEW_REGEX=
# Optional: Celery broker for async vault ingestion (leave unset to use FastAPI BackgroundTasks locally).
REDIS_URL=redis://localhost:6379/0

GEMINI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=
SEARCH_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AI_MODEL=gemini-2.5-flash

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SEED=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=
STRIPE_SUCCESS_URL=http://localhost:5173/enterprise-settings?billing=success
STRIPE_CANCEL_URL=http://localhost:5173/enterprise-settings?billing=cancel

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=
VAULT_MAX_UPLOAD_BYTES=10485760
PINECONE_VECTOR_DIMENSION=768

# --- Observability (optional) ---
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
ENVIRONMENT=development

# --- Supabase (invites, billing metadata; service role server-only) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (invites via Resend; required when invite flow uses email) ---
RESEND_API_KEY=
RESEND_FROM=

# --- Stripe Enterprise Pilot (optional; see backend/routers/billing.py) ---
STRIPE_PRICE_ENTERPRISE_PILOT=

# --- Enterprise / trust (frontend: VITE_*) ---
VITE_STATUS_PAGE_URL=
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_SECURITY_EMAIL=security@example.com
VITE_LEGAL_EMAIL=legal@example.com

# --- OIDC SSO (API) ---
# OIDC_ISSUER=https://your-tenant.okta.com/oauth2/default
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid email profile
OIDC_DEFAULT_ROLE=user

# --- Trust & compliance metadata (API, optional) ---
STATUS_PAGE_URL=
SECURITY_CONTACT_EMAIL=
LEGAL_CONTACT_EMAIL=
TRUST_SOC2_STATUS=readiness
COMPLIANCE_SUBPROCESSOR_VERSION=2026-04-03
DEFAULT_DATA_RETENTION_DAYS=365
WORKSPACE_MFA_REQUIRED=false
SCIM_ENABLED=false
AI_TRAINING_CUSTOMER_DATA=false

# --- Rate limiting uses client IP (slowapi) ---
