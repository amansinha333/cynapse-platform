{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/_/backend/api/$1"
    },
    {
      "source": "/_/backend/(.*)",
      "destination": "/_/backend/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  }
}
